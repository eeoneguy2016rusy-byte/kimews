@model PhotoStudio.Models.Service

@{
    ViewData["Title"] = "Добавить услугу";
}

<div class="container">
    <h2>➕ Добавить услугу</h2>
    <hr />
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        
        <div class="mb-3">
            <label asp-for="ServiceName" class="form-label">Название услуги</label>
            <input asp-for="ServiceName" class="form-control" required />
            <span asp-validation-for="ServiceName" class="text-danger"></span>
        </div>
        
        <div class="mb-3">
            <label asp-for="Price" class="form-label">Цена (₽)</label>
            <input asp-for="Price" class="form-control" type="number" step="0.01" required />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        
        <div class="mb-3">
            <label asp-for="DurationMin" class="form-label">Длительность (минуты)</label>
            <input asp-for="DurationMin" class="form-control" type="number" required />
            <span asp-validation-for="DurationMin" class="text-danger"></span>
        </div>
        
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Описание</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        
        <button type="submit" class="btn btn-primary">✅ Сохранить</button>
        <a asp-action="Index" class="btn btn-secondary">❌ Отмена</a>
    </form>
</div>