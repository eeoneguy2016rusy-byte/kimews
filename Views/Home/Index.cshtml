@{
    ViewData["Title"] = "Блик";
}

<style>
    .home-container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
</style>

<div class="home-container">
    <div class="text-center" style="padding: 50px 20px;">
        <img src="/images/logo.png" alt="Блик" style="max-width: 500px; height: auto; margin-bottom: 30px;" />
        <div style="max-width: 800px; margin: 0 auto;">
            <p style="font-size: 1.2rem; color: #555; line-height: 1.8; margin-bottom: 20px;">
                Добро пожаловать в нашу фотостудию! Мы создаем незабываемые моменты вашей жизни.
            </p>
            <div style="background: #f0f8ff; padding: 30px; border-radius: 10px; margin: 30px 0;">
                <p style="font-size: 1.1rem; margin: 15px 0;">
                    <strong>📸 Профессиональная работа</strong><br>
                    Наша команда опытных фотографов готова воплотить ваши идеи в жизнь
                </p>
                <p style="font-size: 1.1rem; margin: 15px 0;">
                    <strong>💰 Выгодные цены</strong><br>
                    Доступные стоимости услуг без ущерба качеству
                </p>
                <p style="font-size: 1.1rem; margin: 15px 0;">
                    <strong>😊 Довольные клиенты</strong><br>
                    Более 1000 счастливых клиентов уже доверили нам свои самые важные моменты
                </p>
            </div>
        </div>
    </div>
</div>
Привет от участника №1
