@model IEnumerable<PhotoStudio.Models.Employee>

@{
    ViewData["Title"] = "Пользователи";
}

<h2>👤 Пользователи</h2>

<a asp-action="Create" class="btn btn-primary mb-3">➕ Добавить пользователя</a>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Имя</th>
                    <th>Email (Логин)</th>
                    <th>Телефон</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@user.Phone</td>
                        <td>
                            <form method="post" action="@Url.Action("Delete", "Users", new { id = user.Id })" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Вы уверены?')">🗑️ Удалить</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p class="text-muted">Нет пользователей</p>
}
