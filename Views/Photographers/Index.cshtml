@model IEnumerable<PhotoStudio.Models.Photographer>

@{
    var userRole = Context.Session.GetString("UserRole");
    var isAdmin = userRole == "Admin";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📷 Фотографы</h2>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-primary">➕ Добавить фотографа</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ФИО</th>
                <th>Email</th>
                <th>Специализация</th>
                <th>Телефон</th>
                @if (isAdmin)
                {
                    <th class="text-end">Действия</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.Email</td>
                    <td>@item.Specialization</td>
                    <td>@item.Phone</td>
                    @if (isAdmin)
                    {
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">✎ Редактировать</a>
                                
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                      onsubmit="return confirm('Удалить фотографа?');" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">🗑️ Удалить</button>
                                </form>
                            </div>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>