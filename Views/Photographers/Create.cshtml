@model PhotoStudio.Models.Photographer

@{
    ViewData["Title"] = "Добавить фотографа";
}

<h2>📷 Добавить фотографа</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    
    <div class="mb-3">
        <label asp-for="FullName" class="form-label">ФИО</label>
        <input asp-for="FullName" class="form-control" required />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    
    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email (Логин для входа)</label>
        <input asp-for="Email" class="form-control" type="email" required />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    
    <div class="mb-3">
        <label asp-for="Phone" class="form-label">Телефон</label>
        <input asp-for="Phone" class="form-control" required />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>
    
    <div class="mb-3">
        <label asp-for="Specialization" class="form-label">Специализация</label>
        <input asp-for="Specialization" class="form-control" placeholder="Напр. Свадьбы, Портреты" required />
        <span asp-validation-for="Specialization" class="text-danger"></span>
    </div>
    
    <div class="mb-3">
        <label asp-for="ExperienceYears" class="form-label">Стаж (лет)</label>
        <input asp-for="ExperienceYears" type="number" class="form-control" required />
        <span asp-validation-for="ExperienceYears" class="text-danger"></span>
    </div>
    
    <div class="form-group">
        <button type="submit" class="btn btn-primary">✅ Добавить в штат</button>
        <a asp-action="Index" class="btn btn-secondary">❌ Отмена</a>
    </div>
</form>