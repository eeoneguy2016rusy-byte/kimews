@model PhotoStudio.Models.Client

<div class="container">
    <h2 class="mb-4">➕ Добавить клиента</h2>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        
        <div class="mb-3">
            <label asp-for="FullName" class="form-label">ФИО</label>
            <input asp-for="FullName" class="form-control" required />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Phone" class="form-label">Телефон</label>
            <input asp-for="Phone" class="form-control" required />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-control" type="email" required />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Notes" class="form-label">Примечания</label>
            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
        </div>
        <hr />
        <button type="submit" class="btn btn-primary">✅ Сохранить</button>
        <a asp-action="Index" class="btn btn-secondary">❌ Отмена</a>
    </form>
</div>